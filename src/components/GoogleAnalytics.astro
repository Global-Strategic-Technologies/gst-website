---
// Google Analytics 4 Component
// Initializes GA4 tracking for the entire website
// Loads in production and test environments (test requests are mocked)
// Measurement ID should be provided via environment variable

import { PUBLIC_GA_MEASUREMENT_ID, PUBLIC_ENABLE_ANALYTICS } from 'astro:env/client';

const isProduction = import.meta.env.PROD;
const enableAnalytics = PUBLIC_ENABLE_ANALYTICS !== 'false';
const measurementId = PUBLIC_GA_MEASUREMENT_ID;
---

{enableAnalytics && (
  <>
    <script define:vars={{ measurementId }} is:inline>
      // Buffer dataLayer immediately so early gtag() calls are queued
      window.dataLayer = window.dataLayer || [];
      function gtag(...args) {
        dataLayer.push(args);
      }
      window.gtag = gtag;

      // Defer GA configuration until browser is idle to avoid blocking FCP
      (window.requestIdleCallback || function(cb) { setTimeout(cb, 0); })(function() {
        gtag('js', new Date());
        gtag('config', measurementId, {
          send_page_view: true,
        });
      });

      // Track Calendly booking confirmations via postMessage API
      window.addEventListener('message', function (e) {
        if (
          e.origin === 'https://calendly.com' &&
          e.data &&
          e.data.event === 'calendly.event_scheduled'
        ) {
          if (typeof gtag === 'function') {
            gtag('event', 'calendly_booking_confirmed', {
              event_category: 'engagement',
              calendly_event_type:
                (e.data.payload &&
                  e.data.payload.event_type &&
                  e.data.payload.event_type.name) ||
                'unknown',
            });
          }
        }
      });
    </script>

    {isProduction && (
      <script
        async
        is:inline
        src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}
      ></script>
    )}
  </>
)}
